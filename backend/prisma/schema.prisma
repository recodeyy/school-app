generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "tenant"]
}

enum Plan {
  STARTER    @map("starter")
  PRO        @map("pro")
  ENTERPRISE  @map("enterprise")

  @@schema("public")
}

enum UserRole {
  ADMIN    @map("admin")
  TEACHER  @map("teacher")
  STUDENT  @map("student")
  PARENT   @map("parent")
  PRINCIPAL @map("principal")
  ADMISSION_COUNSELOR @map("admission_counselor")
  SUPER_ADMIN @map("super_admin")

  @@schema("public")
}

enum StaffRole {
  ADMIN    @map("admin")
  TEACHER  @map("teacher")
  ADMISSION_COUNSELOR @map("admission_counselor")

  @@schema("public")
}

enum WeekType {
  EVERY   @map("every")
  ODD     @map("odd")
  EVEN    @map("even")

  @@schema("public")
}

enum AttendanceStatus {
  PRESENT  @map("present")
  ABSENT   @map("absent")
  LATE     @map("late")
  EXCUSED  @map("excused")

  @@schema("public")
}

enum ExamType {
  UNIT        @map("unit")
  MIDTERM     @map("midterm")
  FINAL       @map("final")
  PRACTICAL   @map("practical")
  ASSIGNMENT  @map("assignment")

  @@schema("public")
}

enum GroupType {
  CLASS         @map("class")
  SUBJECT       @map("subject")
  CUSTOM        @map("custom")
  ANNOUNCEMENT   @map("announcement")

  @@schema("public")
}

enum MessageType {
  TEXT          @map("text")
  IMAGE         @map("image")
  FILE          @map("file")
  ANNOUNCEMENT   @map("announcement")

  @@schema("public")
}

model Tenant {
  id             String         @id @default(uuid()) @db.Uuid
  name           String         @db.VarChar(200)
  slug           String         @unique @db.VarChar(100)
  plan           Plan
  storageUsedMb  BigInt         @default(0) @map("storage_used_mb")
  storageLimitMb BigInt         @default(5120) @map("storage_limit_mb")
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  schemaName     String         @unique @map("schema_name") @db.VarChar(100)
  billingEmail   String?        @map("billing_email") @db.VarChar(255)

  subscriptions  Subscription[]

  @@map("tenants")
  @@schema("public")
}

model Subscription {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  plan             Plan
  priceMonthly     Decimal  @map("price_monthly") @db.Decimal(10, 2)
  storageGb        Int      @map("storage_gb")
  validUntil       DateTime? @map("valid_until") @db.Date
  paymentGatewayId String?  @map("payment_gateway_id") @db.VarChar(200)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("subscriptions")
  @@schema("public")
}

model User {
  id           String      @id @default(uuid()) @db.Uuid
  name         String      @db.VarChar(200)
  email        String      @unique @db.VarChar(255)
  phone        String?     @db.VarChar(20)
  passwordHash String      @map("password_hash") @db.VarChar(255)
  role         UserRole
  avatarUrl    String?     @map("avatar_url")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  lastLoginAt  DateTime?   @map("last_login_at") @db.Timestamptz(6)

  studentProfile          StudentProfile?
  teacherProfile          TeacherProfile?
  classTeacherOf          SchoolClass[]        @relation("ClassTeacher")
  guardianOf              StudentProfile[]      @relation("Guardian")
  subjectsTaught          Subject[]             @relation("SubjectTeacher")
  attendanceSessionsMarked AttendanceSession[]  @relation("AttendanceMarkedBy")
  attendanceRecordsAsStudent AttendanceRecord[]  @relation("AttendanceStudent")
  resultsAsStudent        Result[]              @relation("ResultStudent")
  resultsEntered          Result[]              @relation("ResultEnteredBy")
  groupsCreated           ChatGroup[]           @relation("GroupCreator")
  messagesSent            ChatMessage[]         @relation("MessageSender")
  filesUploaded           StoredFile[]          @relation("FileUploader")
  notificationsReceived   Notification[]        @relation("NotificationRecipient")

  @@map("users")
  @@schema("tenant")
}

// New: AcademicYear model to manage academic periods across the tenant
model AcademicYear {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(50)
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  isActive  Boolean  @default(false) @map("is_active")

  classes   SchoolClass[] @relation("AcademicYearClasses")

  @@map("academic_years")
  @@schema("tenant")
}

model SchoolClass {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(100)
  // legacy string label (kept for backward compatibility)
  academicYear    String   @map("academic_year") @db.VarChar(20)
  // optional relation to a dedicated AcademicYear row
  academicYearId  String?  @map("academic_year_id") @db.Uuid
  classTeacherId  String?  @map("class_teacher_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  classTeacher    User?              @relation("ClassTeacher", fields: [classTeacherId], references: [id], onDelete: SetNull)
  studentProfiles StudentProfile[]
  subjects        Subject[]
  timetableSlots  TimetableSlot[]
  attendanceSessions AttendanceSession[]
  exams           Exam[]
  groups          ChatGroup[]
  // sections for the class (A, B, ...)
  sections        Section[]
  // optional relation field back to AcademicYear
  academicYearRel AcademicYear? @relation("AcademicYearClasses", fields: [academicYearId], references: [id], onDelete: SetNull)

  @@index([classTeacherId])
  @@map("classes")
  @@schema("tenant")
}

model Section {
  id      String   @id @default(uuid()) @db.Uuid
  name    String   @db.VarChar(20)
  classId String   @map("class_id") @db.Uuid

  schoolClass SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
  @@map("sections")
  @@schema("tenant")
}

model StudentProfile {
  userId            String   @id @map("user_id") @db.Uuid
  classId           String   @map("class_id") @db.Uuid
  rollNumber        String?  @map("roll_number") @db.VarChar(50)
  admissionNumber   String?  @map("admission_number") @db.VarChar(100)
  dob               DateTime? @db.Date
  guardianId        String?  @map("guardian_id") @db.Uuid

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolClass SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  guardian    User?       @relation("Guardian", fields: [guardianId], references: [id], onDelete: SetNull)

  @@index([classId])
  @@index([guardianId])
  @@map("student_profiles")
  @@schema("tenant")
}

model TeacherProfile {
  userId      String   @id @map("user_id") @db.Uuid
  employeeId  String?  @map("employee_id") @db.VarChar(100)
  subjects    String[]
  designation String?  @db.VarChar(100)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("teacher_profiles")
  @@schema("tenant")
}

model Subject {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  code      String?  @db.VarChar(50)
  classId   String   @map("class_id") @db.Uuid
  teacherId String?  @map("teacher_id") @db.Uuid

  schoolClass  SchoolClass       @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher      User?             @relation("SubjectTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  timetableSlots TimetableSlot[]
  attendanceSessions AttendanceSession[]
  results      Result[]

  @@index([classId])
  @@index([teacherId])
  @@map("subjects")
  @@schema("tenant")
}

model TimetableSlot {
  id          String    @id @default(uuid()) @db.Uuid
  classId     String    @map("class_id") @db.Uuid
  subjectId   String    @map("subject_id") @db.Uuid
  dayOfWeek   Int       @map("day_of_week") @db.SmallInt
  startTime   DateTime  @map("start_time") @db.Time(6)
  endTime     DateTime  @map("end_time") @db.Time(6)
  room        String?   @db.VarChar(100)
  weekType    WeekType  @default(EVERY) @map("week_type")

  schoolClass SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject     Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([classId, dayOfWeek])
  @@index([subjectId])
  @@map("timetable_slots")
  @@schema("tenant")
}

// Holidays model
model Holiday {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  date        DateTime @db.Date
  description String?  @db.VarChar(1000)
  isRecurring Boolean  @default(false) @map("is_recurring")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("holidays")
  @@schema("tenant")
}

model AttendanceSession {
  id         String   @id @default(uuid()) @db.Uuid
  classId    String   @map("class_id") @db.Uuid
  subjectId  String   @map("subject_id") @db.Uuid
  teacherId  String   @map("teacher_id") @db.Uuid
  date       DateTime @db.Date
  startTime  DateTime @map("start_time") @db.Time(6)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  schoolClass SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject     Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher     User        @relation("AttendanceMarkedBy", fields: [teacherId], references: [id], onDelete: Restrict)
  records     AttendanceRecord[]

  @@index([classId, date])
  @@index([subjectId])
  @@index([teacherId])
  @@map("attendance_sessions")
  @@schema("tenant")
}

model AttendanceRecord {
  id         String            @id @default(uuid()) @db.Uuid
  sessionId  String            @map("session_id") @db.Uuid
  studentId  String            @map("student_id") @db.Uuid
  status     AttendanceStatus
  markedAt   DateTime          @default(now()) @map("marked_at") @db.Timestamptz(6)
  note       String?

  session AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student User              @relation("AttendanceStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@map("attendance_records")
  @@schema("tenant")
}

model Exam {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  classId     String   @map("class_id") @db.Uuid
  type        ExamType
  totalMarks  Decimal  @map("total_marks") @db.Decimal(6, 2)
  examDate    DateTime @map("exam_date") @db.Date
  isPublished Boolean  @default(false) @map("is_published")

  schoolClass SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  results     Result[]

  @@index([classId])
  @@map("exams")
  @@schema("tenant")
}

model Result {
  id           String   @id @default(uuid()) @db.Uuid
  examId       String   @map("exam_id") @db.Uuid
  studentId    String   @map("student_id") @db.Uuid
  subjectId    String   @map("subject_id") @db.Uuid
  marksObtained Decimal @map("marks_obtained") @db.Decimal(6, 2)
  grade        String?  @db.VarChar(5)
  remarks      String?
  enteredById  String   @map("entered_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  exam      Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)
  student   User   @relation("ResultStudent", fields: [studentId], references: [id], onDelete: Cascade)
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  enteredBy User   @relation("ResultEnteredBy", fields: [enteredById], references: [id], onDelete: Restrict)

  @@unique([examId, studentId, subjectId])
  @@index([studentId])
  @@index([subjectId])
  @@index([enteredById])
  @@map("results")
  @@schema("tenant")
}

model ChatGroup {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(200)
  type        GroupType
  createdById String    @map("created_by") @db.Uuid
  classId     String?   @map("class_id") @db.Uuid
  avatarUrl   String?   @map("avatar_url")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  createdBy   User          @relation("GroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  schoolClass SchoolClass?  @relation(fields: [classId], references: [id], onDelete: SetNull)
  messages    ChatMessage[]
  files       StoredFile[]

  @@index([createdById])
  @@index([classId])
  @@map("groups")
  @@schema("tenant")
}

model ChatMessage {
  id         String    @id @default(uuid()) @db.Uuid
  groupId    String    @map("group_id") @db.Uuid
  senderId   String    @map("sender_id") @db.Uuid
  content    String?
  type       MessageType
  fileUrl    String?   @map("file_url")
  replyToId  String?   @map("reply_to_id") @db.Uuid
  isPinned   Boolean   @default(false) @map("is_pinned")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)

  group    ChatGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender   User        @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo  ChatMessage? @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies  ChatMessage[] @relation("MessageReplies")

  @@index([groupId, createdAt])
  @@index([senderId])
  @@index([replyToId])
  @@map("messages")
  @@schema("tenant")
}

model StoredFile {
  id          String   @id @default(uuid()) @db.Uuid
  uploaderId  String   @map("uploader_id") @db.Uuid
  groupId     String?  @map("group_id") @db.Uuid
  s3Key       String   @map("s3_key")
  fileName    String   @map("file_name") @db.VarChar(500)
  mimeType    String   @map("mime_type") @db.VarChar(100)
  sizeBytes   BigInt   @map("size_bytes")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  uploader User       @relation("FileUploader", fields: [uploaderId], references: [id], onDelete: Cascade)
  group    ChatGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([uploaderId])
  @@index([groupId])
  @@map("files")
  @@schema("tenant")
}

model Notification {
  id           String   @id @default(uuid()) @db.Uuid
  recipientId  String   @map("recipient_id") @db.Uuid
  type         String   @db.VarChar(100)
  title        String   @db.VarChar(300)
  body         String?
  data         Json?
  isRead       Boolean  @default(false) @map("is_read")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  recipient User @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, isRead])
  @@map("notifications")
  @@schema("tenant")
}
