
DATABASE_URL=
NODE_ENV=development
PORT=4000
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# AI Provider — primary (Groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# AI Provider — fallback (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# AI settings
AI_MAX_OUTPUT_TOKENS=2048
AI_TEMPERATURE=0.7
